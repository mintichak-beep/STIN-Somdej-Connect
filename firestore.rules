rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: Check if user is signed in with Firebase Auth
    function isSignedIn() {
      return request.auth != null;
    }
    
    // Helper: Check if user has a verified Teacher or Admin role in the users collection
    function isTeacher() {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher' || 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Teacher' ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin'
        );
    }

    // Default catch-all: Deny all by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Users Collection (Teachers/Admins)
    match /users/{userId} {
      allow read: if isTeacher() || (isSignedIn() && request.auth.uid == userId);
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    // Students Collection
    match /students/{studentId} {
      // Allow single document lookup (get) for student ID search without login
      allow get: if true;
      // Allow teachers to list, search, add, update, or delete student profiles
      allow list: if isTeacher();
      allow write, delete: if isTeacher();
    }

    // Master / Supportive Collections (Courses, Academic Years, Semesters, etc.)
    match /academicYears/{yearId} {
      allow read: if true;
      allow write, delete: if isTeacher();
    }

    match /semesters/{semId} {
      allow read: if true;
      allow write, delete: if isTeacher();
    }

    match /courses/{courseId} {
      allow read: if true;
      allow write, delete: if isTeacher();
    }

    match /practiceGroups/{groupId} {
      allow read: if true;
      allow write, delete: if isTeacher();
    }

    match /sections/{sectionId} {
      allow read: if true;
      allow write, delete: if isTeacher();
    }

    // Accommodation and Dormitory Collections
    match /rooms/{roomId} {
      allow read: if true;
      allow write, delete: if isTeacher();
    }

    match /buildings/{buildingId} {
      allow read: if true;
      allow write, delete: if isTeacher();
    }

    match /floors/{floorId} {
      allow read: if true;
      allow write, delete: if isTeacher();
    }

    match /dorms/{dormId} {
      allow read: if true;
      allow write, delete: if isTeacher();
    }

    // Utilities and Billing Collections
    match /bills/{billId} {
      allow read: if true;
      allow write, delete: if isTeacher();
    }

    match /utilityRecords/{recordId} {
      allow read: if true;
      allow write, delete: if isTeacher();
    }

    // Transportation, Vehicles and Trips Collections
    match /trips/{tripId} {
      allow read: if true;
      allow write, delete: if isTeacher();
    }

    match /vehicles/{vehicleId} {
      allow read: if true;
      allow write, delete: if isTeacher();
    }

    match /vans/{vanId} {
      allow read: if true;
      allow write, delete: if isTeacher();
    }

    match /drivers/{driverId} {
      allow read: if true;
      allow write, delete: if isTeacher();
    }

    // Assignments and Practice Schedules Collections
    match /practiceSchedules/{schedId} {
      allow read: if true;
      allow write, delete: if isTeacher();
    }

    match /practiceAssignments/{assignId} {
      allow read: if true;
      allow write, delete: if isTeacher();
    }

    // Clinical Sites / Hospitals Collections
    match /hospitals/{hospitalId} {
      allow read: if true;
      allow write, delete: if isTeacher();
    }

    match /trainingSites/{siteId} {
      allow read: if true;
      allow write, delete: if isTeacher();
    }

    // Supervision and Quality Control Collections
    match /supervisionSchedules/{schId} {
      allow read: if true;
      allow write, delete: if isTeacher();
    }

    match /supervisionRecords/{recId} {
      allow read: if true;
      allow write, delete: if isTeacher();
    }

    // Document Management Collections
    match /documents/{docId} {
      allow read: if true;
      allow write, delete: if isTeacher();
    }

    match /documentSubmissions/{subId} {
      allow read: if true;
      allow write, delete: if isTeacher();
    }

    // Communication, Announcements and Feedback
    match /announcements/{annId} {
      allow read: if true;
      allow write, delete: if isTeacher();
    }

    match /userFeedbacks/{feedId} {
      allow read, write: if true;
    }

    match /systemIssues/{issueId} {
      allow read: if true;
      allow write, delete: if isTeacher();
    }

    // Audit and Logs Collections
    match /auditLogs/{logId} {
      allow read: if isTeacher();
      allow write: if isSignedIn();
    }

    match /recentActivities/{actId} {
      allow read: if isTeacher();
      allow write: if isSignedIn();
    }
  }
}
